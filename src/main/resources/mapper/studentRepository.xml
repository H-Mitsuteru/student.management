<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="raisetech.student.management.repository.StudentRepository">

  <!-- 受講生の全件検索 -->
  <select id="search" resultType="raisetech.student.management.data.Student">
    SELECT * FROM students
  </select>

  <!-- 受講生の検索 -->
  <select id="searchStudent" resultType="raisetech.student.management.data.Student">
    SELECT * FROM students WHERE student_id = #{studentID}
  </select>

  <!-- 受講生検索（条件検索）
  ・指定された検索条件のみを動的に SQL に追加する
  ・mode = 'OR' の場合は OR 条件検索
  ・それ以外（未指定含む）は AND 条件検索 -->
  <select id="searchByCondition"
          parameterType="raisetech.student.management.DataTransferObject.StudentSearchCondition"
          resultType="raisetech.student.management.data.Student">

<!--    SELECT * FROM students s だと複数コースを持つ受講生が重複してしまうのでDISTINCTで重複を削除 -->
    SELECT DISTINCT s.*
    FROM students s
    LEFT JOIN students_courses sc ON s.student_id = sc.student_id
    WHERE 1=1 <!-- =true のこと -->
    <choose>

      <!-- OR検索 -->
      <when test="mode == @raisetech.student.management.DataTransferObject.SearchMode@OR">
        <trim prefix="AND (" suffix=")" prefixOverrides="OR">
            <if test="studentID != null and studentID != ''">
              OR s.student_id = #{studentID}
            </if>

            <if test="name != null and name != ''">
              OR s.name LIKE CONCAT('%', #{name}, '%')
            </if>

            <if test="email != null and email != ''">
              OR s.e_mail LIKE CONCAT('%', #{email}, '%')
            </if>

            <if test="liveMunicipality != null and liveMunicipality != ''">
              OR s.live_municipality LIKE CONCAT('%', #{liveMunicipality}, '%')
            </if>

            <if test="courseName != null and courseName != ''">
              OR sc.course_name LIKE CONCAT('%', #{courseName}, '%')
            </if>

            <if test="status != null">
              OR sc.status = #{status}
            </if>
        </trim>
      </when>

      <!-- AND検索(デフォルト) -->
      <otherwise>
        <if test="studentID != null and studentID != ''">
          AND s.student_id = #{studentID}
        </if>

        <if test="name != null and name != ''">
          AND s.name LIKE CONCAT('%', #{name}, '%')
        </if>

        <if test="email != null and email != ''">
          AND s.e_mail LIKE CONCAT('%', #{email}, '%')
        </if>

        <if test="liveMunicipality != null and liveMunicipality != ''">
          AND s.live_municipality LIKE CONCAT('%', #{liveMunicipality}, '%')
        </if>

        <if test="courseName != null and courseName != ''">
          AND sc.course_name LIKE CONCAT('%', #{courseName}, '%')
        </if>

<!--        <if test="status != null and status != ''">-->
        <if test="status != null">
          AND sc.status = #{status}
        </if>
      </otherwise>

    </choose>
  </select>
</mapper>
