<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="raisetech.student.management.repository.StudentRepository">

  <!-- 受講生の全件検索 -->
  <select id="search" resultType="raisetech.student.management.data.Student">
    SELECT * FROM students
  </select>

  <!-- 受講生の検索 -->
  <select id="searchStudent" resultType="raisetech.student.management.data.Student">
    SELECT * FROM students WHERE student_id = #{studentID}
  </select>

  <!-- 条件検索 -->
  <select id="searchByCondition" parameterType="map" resultType="raisetech.student.management.data.Student">
    SELECT * FROM students
    WHERE 1=1
    <choose>

      <!-- OR検索 -->
      <when test="mode == 'OR'">
        AND
        <trim prefix="(" suffix=")" prefixOverrides="OR">

          <if test="studentID != null and studentID != ''">
            OR student_id = #{studentID}
          </if>

          <if test="name != null and name != ''">
            OR name LIKE CONCAT('%', #{name}, '%')
          </if>

          <if test="email != null and email != ''">
            OR e_mail LIKE CONCAT('%', #{email}, '%')
          </if>

          <if test="live_Municipality != null and liveMunicipality != ''">
            OR live_municipality LIKE CONCAT('%', #{liveMunicipality}, '%')
          </if>

        </trim>
      </when>

      <!-- AND検索(デフォルト) -->
      <otherwise>
        <if test="studentID != null and studentID != ''">
          AND student_id = #{studentID}
        </if>

        <if test="name != null and name != ''">
          AND name LIKE CONCAT('%', #{name}, '%')
        </if>

        <if test="email != null and email != ''">
          AND e_mail LIKE CONCAT('%', #{email}, '%')
        </if>

        <if test="liveMunicipality != null and liveMunicipality != ''">
          AND live_municipality LIKE CONCAT('%', #{liveMunicipality}, '%')
        </if>
      </otherwise>

    </choose>
  </select>
</mapper>
